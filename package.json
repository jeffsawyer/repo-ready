{
  "name": "@jeffsawyer/repo-ready",
  "version": "0.3.1",
  "description": "Zero-friction release automation setup for JS/TS repos — release-it, changelog, commitlint, lefthook, GitHub Actions, and Slack notifications in one command.",
  "keywords": [
    "release-it",
    "commitlint",
    "lefthook",
    "changelog",
    "semantic-release",
    "github-actions",
    "cli",
    "scaffold",
    "bun",
    "prettier",
    "eslint"
  ],
  "author": "Jeff Sawyer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeffsawyer/repo-ready.git"
  },
  "type": "module",
  "bin": {
    "repo-ready": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "release": "LEFTHOOK=0 release-it --ci",
    "prepare": "npx lefthook install"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "enquirer": "^2.4.1",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.0.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.0.0",
    "release-it": "^19.2.4",
    "tsx": "^4.7.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.0.0"
  },
  "resolutions": {
    "conventional-changelog-conventionalcommits": "8.0.0"
  },
  "overrides": {
    "conventional-changelog-conventionalcommits": "8.0.0"
  },
  "pnpm": {
    "overrides": {
      "conventional-changelog-conventionalcommits": "8.0.0"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
